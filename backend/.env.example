# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS) - Set this to your Vercel frontend URL
# Example: https://your-app.vercel.app
FRONTEND_URL=

# 5SIM Configuration (https://5sim.net)
# Get your API key from: https://5sim.net/ru/account/security
FIVESIM_PROTOCOL_KEY=your_5sim_api_key_here
FIVESIM_API_KEY=your_5sim_api_key_here

# Paystack Configuration (https://paystack.com)
# Get keys from: https://dashboard.paystack.com/settings/developer
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here

# Telegram Bot Configuration
# Get from BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database (if using)
DATABASE_URL=your_database_url_here

