# PRIME SMS HUB - Environ
ment Variables Template
# 
# Copy this file to .env and add your real keys
# NEVER commit .env files to git!

# Paystack API Keys (Get from https://dashboard.paystack.com)
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
VITE_PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxx

# Telegram Bot Token (Get from @BotFather)
VITE_TELEGRAM_BOT_TOKEN=xxxxxxxxx:xxxxxxxxxxxxxxxxxxx

# 5sim API Key (Get from https://5sim.net/settings/security)
VITE_5SIM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend URL
VITE_BACKEND_URL=http://localhost:5000

# App Name
VITE_APP_NAME=PrimeSmsHub
